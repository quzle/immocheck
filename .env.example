# Template config. Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
# .env.local is gitignored, so your real credentials never get committed.
#
# ══════════════════════════════════════════════════════════════
# REQUIRED — fill these in before running the bot
# ══════════════════════════════════════════════════════════════

# Gmail credentials
# Use an app password, not your account password
# Generate at: https://myaccount.google.com/apppasswords
IMAP_EMAIL="your_gmail@gmail.com"
IMAP_PASSWORD="your_gmail_app_password"

# Gmail labels to poll for listing alerts (case-sensitive, exact label names).
# IMAP_FOLDER (ImmoScout24) is required; the others are optional extra platforms —
# leave blank to disable. immobilie1 alerts arrive as Brevo click-tracking links,
# which the parser resolves to the real listing URLs automatically.
IMAP_FOLDER="ImmoScout"
IMAP_WGGESUCHT_FOLDER=""
IMAP_IMMOBILIE1_FOLDER=""

# LLM provider — choose one and fill in the corresponding API key below
LLM_PROVIDER="gemini"                      # Options: gemini, anthropic, ollama
GEMINI_API_KEY="your_gemini_api_key"       # https://aistudio.google.com/apikey
# ANTHROPIC_API_KEY="your_anthropic_key"   # https://console.anthropic.com/
# OPENAI_API_KEY="your_openai_key"

# Search filters — listings outside these limits are rejected without an LLM call
MAX_WARMMIETE=1500                          # Maximum warm rent (€)
MIN_IMAGES=2                                # Minimum number of listing photos


# ══════════════════════════════════════════════════════════════
# OPTIONAL
# ══════════════════════════════════════════════════════════════

# LLM model — omit to use the provider default
LLM_MODEL="gemini-2.0-flash"
# LLM_MODEL="claude-haiku-4-5-20251001"    # Anthropic alternative

# Submission behaviour
# FORCE_EMAIL_FALLBACK=true (recommended): never auto-submit via the browser.
# Every approved application is queued and emailed to you with manual submission
# instructions. Browser auto-submission is frequently blocked by ImmoScout24's CAPTCHA.
FORCE_EMAIL_FALLBACK="true"
# DRY_RUN only affects the browser path (i.e. when FORCE_EMAIL_FALLBACK=false):
# true = go through the motions but skip the final "submit" click.
# It does NOT disable the email fallback — those emails are sent either way.
DRY_RUN="true"
PLAYWRIGHT_HEADLESS="false"

# Location scoring (optional) — injected into the apartment scoring prompt.
# Only needed if you want commute-aware ranking; safe to leave generic otherwise.
OFFICE_LOCATION="your office address, City (~postcode)"
TRANSIT_LINES="your nearby transit lines, e.g. U4, U5, S7"

# Google Maps Static API key (optional). When set, notification emails embed a
# static map of the listing's location. Leave empty to disable the map.
# Enable the "Maps Static API" and create a key at:
# https://console.cloud.google.com/google/maps-apis/credentials
MAPS_API_KEY=""

# Dedicated Chrome profile for browser automation. Kept separate from your
# everyday Chrome so both can run at once. Created automatically on first run;
# log in to ImmoScout24 once via `python test_login.py`. Leave this as-is.
CHROME_USER_DATA_DIR="~/.chrome_profile_immocheck"

# How often to check Gmail for new alerts (seconds)
POLL_INTERVAL="300"

# Email notification recipients (comma-separated; defaults to IMAP_EMAIL if unset)
NOTIFICATION_RECIPIENTS="your_gmail@gmail.com"

# Push notifications via ntfy.sh — leave blank to disable
# Create a unique private topic at ntfy.sh (treat it like a password)
NTFY_TOPIC="immocheck-your_unique_topic_here"

# Translate drafted applications to English for your review (requires DeepL key)
ENABLE_TRANSLATION="false"
TRANSLATION_TARGET_LANGUAGE="EN-GB"
DEEPL_API_KEY="your_deepl_api_key"         # https://www.deepl.com/pro-api

# Parallel LLM calls (increase to 3–5 for cloud providers; keep at 1 for Ollama)
LLM_CONCURRENCY="1"

# Use mock LLM responses for development (no API calls, no costs)
MOCK_LLM="false"

# Gmail IMAP server (change only if not using Gmail)
IMAP_SERVER="imap.gmail.com"

# Ollama settings — only used when LLM_PROVIDER=ollama
OLLAMA_HOST="http://localhost:11434"
OLLAMA_MODEL="qwen3:14b"
OLLAMA_TIMEOUT="600"
OLLAMA_NUM_CTX="8192"
